<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Free AI automation resources, guides, and tools from Automate&Earn. Download free lead magnets to 10x your business output.">
  <title>Free Resources — Automate&Earn</title>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700;800;900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --dark: #0a0a0f; --card: #13131f; --card-2: #1a1a2e;
      --gold: #d4af37; --gold-light: #f0d060;
      --teal: #00897b; --teal-light: #4db6ac;
      --text: #e8e8f0; --text-dim: #9090a8; --text-faint: #5a5a72;
      --border: rgba(212,175,55,0.15); --border-2: rgba(255,255,255,0.07);
      --green: #22c55e;
    }
    body { font-family: 'Inter', sans-serif; background: var(--dark); color: var(--text); min-height: 100vh; -webkit-font-smoothing: antialiased; }

    /* ── HEADER ── */
    header {
      border-bottom: 1px solid var(--border);
      padding: 0 24px;
      position: sticky; top: 0; z-index: 100;
      background: rgba(10,10,15,0.95);
      backdrop-filter: blur(12px);
    }
    .header-inner {
      max-width: 1100px; margin: 0 auto;
      display: flex; align-items: center; justify-content: space-between;
      height: 64px;
    }
    .logo { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: 18px; color: var(--gold); letter-spacing: 0.05em; text-decoration: none; }
    .header-badge { padding: 4px 12px; background: rgba(212,175,55,0.1); border: 1px solid rgba(212,175,55,0.25); border-radius: 100px; font-size: 11px; font-weight: 700; font-family: 'Montserrat', sans-serif; letter-spacing: 0.08em; text-transform: uppercase; color: var(--gold); }

    /* ── HERO ── */
    .hero { text-align: center; padding: 72px 24px 48px; }
    .hero-eyebrow { font-size: 11px; font-weight: 800; font-family: 'Montserrat', sans-serif; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-bottom: 16px; }
    .hero h1 { font-family: 'Montserrat', sans-serif; font-size: clamp(28px, 5vw, 48px); font-weight: 900; line-height: 1.1; color: var(--text); margin-bottom: 16px; }
    .hero h1 span { background: linear-gradient(90deg, var(--gold), var(--gold-light)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .hero p { font-size: 16px; color: var(--text-dim); max-width: 520px; margin: 0 auto 32px; line-height: 1.7; }
    .hero-stats { display: flex; justify-content: center; gap: 32px; flex-wrap: wrap; }
    .hero-stat { text-align: center; }
    .hero-stat-num { font-family: 'Montserrat', sans-serif; font-size: 24px; font-weight: 900; color: var(--gold); }
    .hero-stat-label { font-size: 11px; color: var(--text-faint); text-transform: uppercase; letter-spacing: 0.08em; margin-top: 2px; }

    /* ── GRID ── */
    .store-section { max-width: 1100px; margin: 0 auto; padding: 48px 24px 80px; }
    .section-label { font-size: 10px; font-weight: 800; font-family: 'Montserrat', sans-serif; letter-spacing: 0.18em; text-transform: uppercase; color: var(--text-dim); margin-bottom: 24px; }
    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; }

    /* ── PRODUCT CARD ── */
    .card {
      background: var(--card); border: 1px solid var(--border-2);
      border-radius: 16px; overflow: hidden;
      display: flex; flex-direction: column;
      transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
    }
    .card:hover { transform: translateY(-4px); border-color: rgba(212,175,55,0.3); box-shadow: 0 20px 60px rgba(0,0,0,0.4); }
    .card-cover {
      width: 100%; aspect-ratio: 3/4; overflow: hidden;
      background: var(--card-2); position: relative;
      display: flex; align-items: center; justify-content: center;
    }
    .card-cover img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .card-cover-placeholder { text-align: center; padding: 24px; }
    .card-cover-placeholder .ph-icon { font-size: 48px; margin-bottom: 12px; }
    .card-cover-placeholder .ph-title { font-family: 'Montserrat', sans-serif; font-size: 14px; font-weight: 800; color: var(--gold); line-height: 1.3; }
    .card-badge { position: absolute; top: 12px; right: 12px; padding: 4px 10px; background: rgba(34,197,94,0.15); border: 1px solid rgba(34,197,94,0.35); border-radius: 100px; font-size: 10px; font-weight: 800; font-family: 'Montserrat', sans-serif; letter-spacing: 0.08em; color: var(--green); }
    .card-body { padding: 20px; flex: 1; display: flex; flex-direction: column; }
    .card-title { font-family: 'Montserrat', sans-serif; font-size: 15px; font-weight: 800; color: var(--text); line-height: 1.3; margin-bottom: 8px; }
    .card-desc { font-size: 13px; color: var(--text-dim); line-height: 1.6; flex: 1; margin-bottom: 16px; }
    .card-btn {
      display: block; width: 100%; padding: 13px;
      background: linear-gradient(135deg, var(--gold), var(--gold-light));
      color: #000; font-family: 'Montserrat', sans-serif;
      font-size: 13px; font-weight: 800; letter-spacing: 0.06em;
      text-align: center; border: none; border-radius: 10px;
      cursor: pointer; transition: opacity 0.2s, transform 0.1s;
      text-transform: uppercase;
    }
    .card-btn:hover { opacity: 0.92; transform: scale(1.01); }

    /* ── EMPTY STATE ── */
    .empty { text-align: center; padding: 80px 24px; color: var(--text-dim); }
    .empty-icon { font-size: 48px; margin-bottom: 16px; }

    /* ── MODAL ── */
    .modal-overlay {
      position: fixed; inset: 0; z-index: 1000;
      background: rgba(0,0,0,0.85); backdrop-filter: blur(4px);
      display: flex; align-items: center; justify-content: center;
      padding: 24px; opacity: 0; pointer-events: none;
      transition: opacity 0.25s;
    }
    .modal-overlay.open { opacity: 1; pointer-events: all; }
    .modal {
      background: var(--card-2); border: 1px solid rgba(212,175,55,0.25);
      border-radius: 20px; padding: 36px; width: 100%; max-width: 440px;
      transform: translateY(20px); transition: transform 0.25s;
      position: relative;
    }
    .modal-overlay.open .modal { transform: translateY(0); }
    .modal-close { position: absolute; top: 16px; right: 16px; background: none; border: none; color: var(--text-dim); font-size: 22px; cursor: pointer; line-height: 1; padding: 4px; }
    .modal-close:hover { color: var(--text); }
    .modal-eyebrow { font-size: 10px; font-weight: 800; font-family: 'Montserrat', sans-serif; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gold); margin-bottom: 8px; }
    .modal-title { font-family: 'Montserrat', sans-serif; font-size: 18px; font-weight: 900; color: var(--text); margin-bottom: 6px; line-height: 1.3; }
    .modal-sub { font-size: 13px; color: var(--text-dim); margin-bottom: 24px; }
    .form-group { margin-bottom: 14px; }
    .form-label { display: block; font-size: 11px; font-weight: 700; font-family: 'Montserrat', sans-serif; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-dim); margin-bottom: 6px; }
    .form-input {
      width: 100%; padding: 13px 16px;
      background: rgba(255,255,255,0.05); border: 1px solid var(--border-2);
      border-radius: 10px; color: var(--text); font-size: 14px; font-family: 'Inter', sans-serif;
      outline: none; transition: border-color 0.2s;
    }
    .form-input:focus { border-color: rgba(212,175,55,0.4); }
    .form-input::placeholder { color: var(--text-faint); }
    .modal-btn {
      width: 100%; padding: 14px;
      background: linear-gradient(135deg, var(--gold), var(--gold-light));
      color: #000; font-family: 'Montserrat', sans-serif;
      font-size: 14px; font-weight: 800; letter-spacing: 0.06em;
      border: none; border-radius: 10px; cursor: pointer;
      margin-top: 8px; transition: opacity 0.2s;
      text-transform: uppercase;
    }
    .modal-btn:hover { opacity: 0.9; }
    .modal-btn:disabled { opacity: 0.5; cursor: not-allowed; }
    .modal-privacy { text-align: center; margin-top: 12px; font-size: 11px; color: var(--text-faint); }
    .modal-error { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); border-radius: 8px; padding: 10px 14px; font-size: 13px; color: #fca5a5; margin-bottom: 14px; display: none; }

    /* ── FOOTER ── */
    footer { border-top: 1px solid var(--border); padding: 32px 24px; text-align: center; }
    .footer-inner { max-width: 1100px; margin: 0 auto; }
    .footer-brand { font-family: 'Montserrat', sans-serif; font-size: 16px; font-weight: 900; color: var(--gold); margin-bottom: 8px; }
    .footer-sub { font-size: 13px; color: var(--text-faint); }
    .footer-links { display: flex; justify-content: center; gap: 20px; margin-top: 16px; }
    .footer-links a { font-size: 12px; color: var(--text-dim); text-decoration: none; }
    .footer-links a:hover { color: var(--gold); }

    @media (max-width: 600px) {
      .hero { padding: 48px 16px 32px; }
      .hero-stats { gap: 20px; }
      .store-section { padding: 32px 16px 60px; }
      .grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<header>
  <div class="header-inner">
    <a href="/" class="logo">AUTOMATE&EARN</a>
    <span class="header-badge">Free Resources</span>
  </div>
</header>

<section class="hero">
  <div class="hero-eyebrow">— Free Downloads</div>
  <h1>AI Tools & Guides<br><span>Built to 10× Your Output</span></h1>
  <p>Download any resource free. No payment. Just your name and email so we can send you more tools like these.</p>
  <div class="hero-stats">
    <div class="hero-stat">
      <div class="hero-stat-num"><%= products.length %></div>
      <div class="hero-stat-label">Free Resources</div>
    </div>
    <div class="hero-stat">
      <div class="hero-stat-num">100%</div>
      <div class="hero-stat-label">Free Forever</div>
    </div>
    <div class="hero-stat">
      <div class="hero-stat-num">⚡</div>
      <div class="hero-stat-label">Instant Download</div>
    </div>
  </div>
</section>

<section class="store-section">
  <div class="section-label">All Resources</div>

  <% if (products.length === 0) { %>
    <div class="empty">
      <div class="empty-icon">📦</div>
      <div>Resources coming soon. Check back shortly.</div>
    </div>
  <% } else { %>
    <div class="grid">
      <% products.forEach(product => { %>
        <div class="card">
          <div class="card-cover">
            <% if (product.cover_image) { %>
              <img src="/uploads/images/<%= product.cover_image %>" alt="<%= product.title %>">
            <% } else { %>
              <div class="card-cover-placeholder">
                <div class="ph-icon">📄</div>
                <div class="ph-title"><%= product.title %></div>
              </div>
            <% } %>
            <span class="card-badge">FREE</span>
          </div>
          <div class="card-body">
            <div class="card-title"><%= product.title %></div>
            <div class="card-desc"><%= product.description %></div>
            <button class="card-btn" onclick="openModal(<%= product.id %>, '<%= product.title.replace(/'/g, "\\'") %>')">
              ⬇ Download Free
            </button>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</section>

<!-- MODAL -->
<div class="modal-overlay" id="modalOverlay" onclick="handleOverlayClick(event)">
  <div class="modal">
    <button class="modal-close" onclick="closeModal()">✕</button>
    <div class="modal-eyebrow">— Free Download</div>
    <div class="modal-title" id="modalTitle">Resource Title</div>
    <div class="modal-sub">Enter your details and your download starts instantly.</div>
    <div class="modal-error" id="modalError"></div>
    <form id="downloadForm" onsubmit="submitDownload(event)">
      <input type="hidden" id="productId" value="">
      <div class="form-group">
        <label class="form-label" for="nameInput">Your Name</label>
        <input class="form-input" type="text" id="nameInput" placeholder="e.g. Alex Johnson" required autocomplete="name">
      </div>
      <div class="form-group">
        <label class="form-label" for="emailInput">Email Address</label>
        <input class="form-input" type="email" id="emailInput" placeholder="you@example.com" required autocomplete="email">
      </div>
      <button class="modal-btn" type="submit" id="submitBtn">⬇ Get My Free Download</button>
    </form>
    <div class="modal-privacy">🔒 No spam. Unsubscribe anytime.</div>
  </div>
</div>

<footer>
  <div class="footer-inner">
    <div class="footer-brand">AUTOMATE&EARN</div>
    <div class="footer-sub">AI automation tools and resources for solopreneurs</div>
    <div class="footer-links">
      <a href="https://twitter.com/automatearnai" target="_blank">Twitter/X</a>
      <a href="https://linkedin.com/in/automatearnai" target="_blank">LinkedIn</a>
    </div>
  </div>
</footer>

<script>
  function openModal(productId, title) {
    document.getElementById('productId').value = productId;
    document.getElementById('modalTitle').textContent = title;
    document.getElementById('modalError').style.display = 'none';
    document.getElementById('downloadForm').reset();
    document.getElementById('submitBtn').disabled = false;
    document.getElementById('submitBtn').textContent = '⬇ Get My Free Download';
    document.getElementById('modalOverlay').classList.add('open');
    setTimeout(() => document.getElementById('nameInput').focus(), 300);
  }

  function closeModal() {
    document.getElementById('modalOverlay').classList.remove('open');
  }

  function handleOverlayClick(e) {
    if (e.target === document.getElementById('modalOverlay')) closeModal();
  }

  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

  async function submitDownload(e) {
    e.preventDefault();
    const productId = document.getElementById('productId').value;
    const name      = document.getElementById('nameInput').value.trim();
    const email     = document.getElementById('emailInput').value.trim();
    const btn       = document.getElementById('submitBtn');
    const errBox    = document.getElementById('modalError');

    btn.disabled = true;
    btn.textContent = 'Preparing download...';
    errBox.style.display = 'none';

    try {
      const res = await fetch('/download/' + productId, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email })
      });

      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        throw new Error(data.error || 'Something went wrong. Please try again.');
      }

      // Trigger file download
      const blob = await res.blob();
      const url  = URL.createObjectURL(blob);
      const a    = document.createElement('a');
      a.href     = url;
      a.download = '';
      document.body.appendChild(a);
      a.click();
      a.remove();
      URL.revokeObjectURL(url);

      btn.textContent = '✅ Download Started!';
      setTimeout(() => closeModal(), 2000);

    } catch (err) {
      errBox.textContent = err.message;
      errBox.style.display = 'block';
      btn.disabled = false;
      btn.textContent = '⬇ Get My Free Download';
    }
  }
</script>

</body>
</html>
