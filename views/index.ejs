<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Automate&amp;Earn | Free AI Automation Tools</title>
  <link rel="icon" type="image/png" href="/brand-logo.png">
  <link rel="icon" type="image/svg+xml" href="/logo.svg">
  <meta name="description" content="Download free AI automation tools, playbooks, and templates. Built for entrepreneurs who ship fast.">
  <meta property="og:title" content="Automate&Earn — Free AI Automation Tools">
  <meta property="og:description" content="Practical AI tools and automation templates for solopreneurs. Download instantly, no payment.">
  <meta property="og:type" content="website">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,400;0,700;0,800;0,900;1,700&family=Barlow:wght@400;500;600&display=swap" rel="stylesheet">

  <style>
    /* ─── Design tokens (OKLCH) ───────────────────────────── */
    :root {
      --bg:         oklch(0.10 0.008 75);
      --bg-2:       oklch(0.14 0.008 75);
      --bg-3:       oklch(0.18 0.010 75);
      --line:       oklch(0.22 0.008 75);
      --gold:       oklch(0.76 0.14 88);
      --gold-mid:   oklch(0.62 0.11 88);
      --gold-dim:   oklch(0.44 0.08 88);
      --text:       oklch(0.93 0.005 75);
      --text-2:     oklch(0.68 0.005 75);
      --text-3:     oklch(0.46 0.005 75);
      --green:      oklch(0.72 0.15 148);
      --green-bg:   oklch(0.16 0.04 148);
      --green-line: oklch(0.30 0.08 148);
      --red:        oklch(0.68 0.18 30);
      --red-bg:     oklch(0.14 0.04 30);
      --red-line:   oklch(0.28 0.08 30);
      --ff-d: 'Barlow Condensed', sans-serif;
      --ff-b: 'Barlow', sans-serif;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--ff-b);
      line-height: 1.6;
    }

    /* ─── Nav ─────────────────────────────────────────────── */
    .nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: var(--bg);
      border-bottom: 1px solid var(--line);
      padding: 0 clamp(1.25rem, 5vw, 4rem);
      height: 56px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .nav-logo {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      text-decoration: none;
    }

    .nav-logo img {
      width: 38px;
      height: 38px;
      object-fit: cover;
      object-position: center 12%;
      display: block;
    }

    .nav-wordmark {
      font-family: var(--ff-d);
      font-weight: 900;
      font-size: 1.15rem;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--text);
    }

    .nav-wordmark em { color: var(--gold); font-style: normal; }

    .nav-pill {
      font-family: var(--ff-b);
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--text-3);
      border: 1px solid var(--line);
      padding: 0.3rem 0.8rem;
      white-space: nowrap;
    }

    /* ─── Alerts ───────────────────────────────────────────── */
    .alert {
      padding: 1rem clamp(1.25rem, 5vw, 4rem);
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .alert--success { background: var(--green-bg); border-bottom: 1px solid var(--green-line); }
    .alert--error   { background: var(--red-bg);   border-bottom: 1px solid var(--red-line); }

    .alert-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      flex-shrink: 0;
    }

    .alert--success .alert-dot { background: var(--green); }
    .alert--error   .alert-dot { background: var(--red); }

    .alert-body strong {
      display: block;
      font-family: var(--ff-d);
      font-weight: 800;
      font-size: 0.95rem;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .alert--success .alert-body strong { color: var(--green); }
    .alert--error   .alert-body strong { color: var(--red); }
    .alert-body p { font-size: 0.82rem; color: var(--text-2); }

    /* ─── Hero ─────────────────────────────────────────────── */
    .hero {
      min-height: calc(100svh - 56px);
      padding: clamp(4rem, 10vh, 8rem) clamp(1.25rem, 5vw, 4rem) clamp(2rem, 5vh, 4rem);
      display: grid;
      grid-template-columns: 1fr min(420px, 38vw);
      grid-template-rows: 1fr auto;
      gap: 0 clamp(2rem, 5vw, 6rem);
      align-content: center;
    }

    .hero-left {
      grid-column: 1;
      grid-row: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .hero-kicker {
      font-family: var(--ff-b);
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--gold-mid);
      margin-bottom: 1.5rem;
    }

    .hero-h1 {
      font-family: var(--ff-d);
      font-weight: 900;
      font-size: clamp(4.5rem, 11vw, 10rem);
      line-height: 0.90;
      letter-spacing: -0.01em;
      text-transform: uppercase;
      color: var(--text);
    }

    .hero-h1 .gold { color: var(--gold); }

    .hero-right {
      grid-column: 2;
      grid-row: 1;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding-bottom: 0.5rem;
    }

    .hero-desc {
      font-size: 0.98rem;
      line-height: 1.7;
      color: var(--text-2);
      max-width: 44ch;
      margin-bottom: 2rem;
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      background: var(--gold);
      color: var(--bg);
      font-family: var(--ff-d);
      font-weight: 800;
      font-size: 0.95rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      text-decoration: none;
      padding: 0.8rem 1.6rem;
      border: none;
      cursor: pointer;
      transition: background 0.14s;
      align-self: flex-start;
    }

    .btn-primary:hover { background: oklch(0.83 0.14 88); }
    .btn-primary svg   { width: 14px; height: 14px; }

    .hero-baseline {
      grid-column: 1 / -1;
      grid-row: 2;
      display: flex;
      align-items: center;
      gap: 1rem;
      padding-top: clamp(2rem, 5vh, 4rem);
    }

    .hero-rule { flex: 0 0 48px; height: 1px; background: var(--line); }

    .hero-baseline-text {
      font-size: 0.68rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--text-3);
    }

    /* ─── Resources ────────────────────────────────────────── */
    .resources {
      padding: clamp(3rem, 8vh, 6rem) clamp(1.25rem, 5vw, 4rem);
    }

    .section-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      border-top: 1px solid var(--line);
      padding-top: 1.25rem;
      margin-bottom: clamp(2rem, 5vw, 4rem);
    }

    .section-label {
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--text-3);
    }

    .section-tally {
      font-family: var(--ff-d);
      font-weight: 700;
      font-size: 0.85rem;
      letter-spacing: 0.06em;
      color: var(--gold-mid);
    }

    /* ─── Product rows (numbered list, not a card grid) ───── */
    .product-list { display: flex; flex-direction: column; }

    .product-row {
      display: grid;
      grid-template-columns: 56px 1fr 128px;
      gap: 0 2rem;
      padding: 2.75rem 0;
      border-top: 1px solid var(--line);
      align-items: start;
    }

    .product-row:last-child { border-bottom: 1px solid var(--line); }

    .product-index {
      font-family: var(--ff-d);
      font-weight: 900;
      font-size: 2.8rem;
      line-height: 1;
      color: var(--line);
      letter-spacing: -0.02em;
      padding-top: 0.15rem;
      user-select: none;
    }

    .product-body { min-width: 0; }

    .product-title {
      font-family: var(--ff-d);
      font-weight: 800;
      font-size: clamp(1.7rem, 3.2vw, 2.6rem);
      line-height: 1.05;
      letter-spacing: -0.01em;
      text-transform: uppercase;
      color: var(--text);
      margin-bottom: 0.6rem;
    }

    .product-desc {
      font-size: 0.88rem;
      line-height: 1.65;
      color: var(--text-2);
      max-width: 56ch;
      margin-bottom: 1.25rem;
    }

    .product-toggle {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      font-family: var(--ff-d);
      font-weight: 700;
      font-size: 0.85rem;
      letter-spacing: 0.10em;
      text-transform: uppercase;
      color: var(--gold);
      background: none;
      border: none;
      cursor: pointer;
      padding: 0;
      transition: color 0.12s;
    }

    .product-toggle:hover { color: oklch(0.85 0.14 88); }

    .product-toggle svg {
      width: 12px;
      height: 12px;
      transition: transform 0.22s ease-out;
    }

    .product-toggle.open svg { transform: rotate(90deg); }

    /* ─── Inline form (grid-row collapse, no GSAP needed) ─── */
    .product-form-wrap {
      display: grid;
      grid-template-rows: 0fr;
      transition: grid-template-rows 0.30s ease-out;
    }

    .product-form-wrap.open {
      grid-template-rows: 1fr;
      margin-top: 1.5rem;
    }

    .product-form-inner { overflow: hidden; }

    .inline-form {
      background: var(--bg-2);
      border: 1px solid var(--line);
      padding: 1.75rem;
      max-width: 440px;
    }

    .inline-form-title {
      font-family: var(--ff-d);
      font-weight: 800;
      font-size: 1.15rem;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--text);
      margin-bottom: 0.2rem;
    }

    .inline-form-sub {
      font-size: 0.78rem;
      color: var(--text-3);
      letter-spacing: 0.04em;
      margin-bottom: 1.25rem;
    }

    .form-field {
      display: block;
      width: 100%;
      padding: 0.7rem 0.9rem;
      background: var(--bg);
      border: 1px solid var(--line);
      color: var(--text);
      font-family: var(--ff-b);
      font-size: 0.88rem;
      outline: none;
      transition: border-color 0.14s;
      margin-bottom: 0.6rem;
    }

    .form-field:focus { border-color: var(--gold-dim); }
    .form-field::placeholder { color: var(--text-3); }

    .form-submit {
      width: 100%;
      padding: 0.8rem;
      background: var(--gold);
      color: var(--bg);
      font-family: var(--ff-d);
      font-weight: 800;
      font-size: 0.95rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      border: none;
      cursor: pointer;
      transition: background 0.14s;
    }

    .form-submit:hover { background: oklch(0.83 0.14 88); }

    .form-legal {
      font-size: 0.68rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--text-3);
      margin-top: 0.75rem;
    }

    /* ─── Cover image ──────────────────────────────────────── */
    .product-cover {
      width: 128px;
      height: 170px;
      object-fit: cover;
      display: block;
    }

    .product-cover-placeholder {
      width: 128px;
      height: 170px;
      background: var(--bg-2);
      border: 1px solid var(--line);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .product-cover-placeholder svg { width: 28px; height: 28px; color: var(--line); }

    /* ─── Empty state ──────────────────────────────────────── */
    .empty { padding: 5rem 0; }

    .empty-title {
      font-family: var(--ff-d);
      font-weight: 800;
      font-size: 1.4rem;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--text-2);
      margin-bottom: 0.3rem;
    }

    .empty-sub { font-size: 0.85rem; color: var(--text-3); }

    /* ─── Footer ────────────────────────────────────────────── */
    .footer {
      padding: 1.75rem clamp(1.25rem, 5vw, 4rem);
      border-top: 1px solid var(--line);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .footer-mark {
      font-family: var(--ff-d);
      font-weight: 800;
      font-size: 0.9rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--text-2);
    }

    .footer-mark em { color: var(--gold); font-style: normal; }

    .footer-note {
      font-size: 0.68rem;
      letter-spacing: 0.10em;
      text-transform: uppercase;
      color: var(--text-3);
    }

    /* ─── Page-load reveal (CSS keyframes, no GSAP) ─────────── */
    .reveal { opacity: 0; transform: translateY(18px); }

    @keyframes fadeUp { to { opacity: 1; transform: translateY(0); } }

    .reveal-1 { animation: fadeUp 0.50s 0.05s ease-out forwards; }
    .reveal-2 { animation: fadeUp 0.55s 0.15s ease-out forwards; }
    .reveal-3 { animation: fadeUp 0.50s 0.28s ease-out forwards; }
    .reveal-4 { animation: fadeUp 0.45s 0.42s ease-out forwards; }

    /* ─── Mobile ────────────────────────────────────────────── */
    @media (max-width: 720px) {
      .hero {
        grid-template-columns: 1fr;
        grid-template-rows: auto auto auto;
        min-height: auto;
        padding-top: 3rem;
        padding-bottom: 2rem;
      }

      .hero-right {
        grid-column: 1;
        grid-row: 2;
        justify-content: flex-start;
        padding-bottom: 0;
      }

      .hero-baseline { grid-row: 3; }

      .product-row { grid-template-columns: 44px 1fr; }
      .product-cover, .product-cover-placeholder { display: none; }

      .footer { flex-direction: column; gap: 0.5rem; text-align: center; }
    }

    @media (prefers-reduced-motion: reduce) {
      .reveal { opacity: 1; transform: none; animation: none; }
    }
  </style>
</head>
<body>

  <!-- ── Nav ─────────────────────────────────────────────── -->
  <nav class="nav">
    <a href="/" class="nav-logo">
      <img src="/brand-logo.png" alt="Automate&amp;Earn logo" onerror="this.src='/logo.svg'">
      <span class="nav-wordmark">Automate<em>&amp;</em>Earn</span>
    </a>
    <span class="nav-pill"><%= products.length %> Free Resource<%= products.length !== 1 ? 's' : '' %></span>
  </nav>

  <% if (success) { %>
  <div class="alert alert--success" role="status">
    <div class="alert-dot"></div>
    <div class="alert-body">
      <strong>Download ready</strong>
      <p>Your guide is on its way. Check your inbox.</p>
    </div>
  </div>
  <% } %>

  <% if (error) { %>
  <div class="alert alert--error" role="alert">
    <div class="alert-dot"></div>
    <div class="alert-body">
      <strong>Something went wrong</strong>
      <p><%= error %></p>
    </div>
  </div>
  <% } %>

  <!-- ── Hero ───────────────────────────────────────────── -->
  <section class="hero" aria-label="Introduction">
    <div class="hero-left">
      <p class="hero-kicker reveal reveal-1">Free Downloads &mdash; No Payment Needed</p>
      <h1 class="hero-h1 reveal reveal-2">
        Automate<br>
        <span class="gold">Your<br>Income.</span>
      </h1>
    </div>

    <div class="hero-right reveal reveal-3">
      <p class="hero-desc">
        Every resource here is a practical tool, playbook, or template from real AI automation workflows. Enter your name and email &mdash; your PDF downloads immediately.
      </p>
      <a href="#resources" class="btn-primary">
        Browse Resources
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="12" y1="5" x2="12" y2="19"/>
          <polyline points="19 12 12 19 5 12"/>
        </svg>
      </a>
    </div>

    <div class="hero-baseline reveal reveal-4" aria-hidden="true">
      <div class="hero-rule"></div>
      <span class="hero-baseline-text">Scroll to explore</span>
    </div>
  </section>

  <!-- ── Resources ──────────────────────────────────────── -->
  <section class="resources" id="resources" aria-label="Free Resources">
    <div class="section-header">
      <span class="section-label">Free Resources</span>
      <span class="section-tally"><%= products.length %> Guide<%= products.length !== 1 ? 's' : '' %></span>
    </div>

    <% if (products.length === 0) { %>
    <div class="empty">
      <p class="empty-title">Guides loading soon</p>
      <p class="empty-sub">New resources drop shortly. Check back in a moment.</p>
    </div>
    <% } else { %>
    <div class="product-list">
      <% products.forEach((product, i) => { %>
      <article class="product-row" id="row-<%= product.id %>">

        <span class="product-index" aria-hidden="true"><%= String(i + 1).padStart(2, '0') %></span>

        <div class="product-body">
          <h2 class="product-title"><%= product.title %></h2>
          <p class="product-desc"><%= product.description %></p>

          <button
            class="product-toggle"
            id="toggle-<%= product.id %>"
            aria-expanded="false"
            aria-controls="form-<%= product.id %>"
            onclick="handleToggle(<%= product.id %>)"
          >
            <span>Get Free Access</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </button>

          <div
            class="product-form-wrap"
            id="form-<%= product.id %>"
            role="region"
            aria-label="Download form for <%= product.title %>"
          >
            <div class="product-form-inner">
              <div class="inline-form">
                <p class="inline-form-title">Get This Free</p>
                <p class="inline-form-sub">Enter your email. Download starts instantly.</p>
                <form method="POST" action="/download">
                  <input type="hidden" name="product_id" value="<%= product.id %>">
                  <input
                    class="form-field"
                    type="text"
                    name="name"
                    placeholder="Your Name"
                    autocomplete="name"
                    required
                  >
                  <input
                    class="form-field"
                    type="email"
                    name="email"
                    placeholder="Your Email"
                    autocomplete="email"
                    required
                  >
                  <button class="form-submit" type="submit">Download Now</button>
                </form>
                <p class="form-legal">No spam. Unsubscribe anytime.</p>
              </div>
            </div>
          </div>
        </div>

        <% if (product.cover_image) { %>
        <img
          class="product-cover"
          src="/uploads/images/<%= product.cover_image %>"
          alt="<%= product.title %> cover"
          loading="lazy"
          width="128"
          height="170"
        >
        <% } else { %>
        <div class="product-cover-placeholder" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="4" y="2" width="16" height="20" rx="1"/>
            <line x1="8" y1="7" x2="16" y2="7"/>
            <line x1="8" y1="11" x2="16" y2="11"/>
            <line x1="8" y1="15" x2="12" y2="15"/>
          </svg>
        </div>
        <% } %>

      </article>
      <% }) %>
    </div>
    <% } %>
  </section>

  <!-- ── Footer ─────────────────────────────────────────── -->
  <footer class="footer">
    <span class="footer-mark">Automate<em>&amp;</em>Earn</span>
    <span class="footer-note">No spam &middot; Unsubscribe anytime</span>
  </footer>

  <script>
    function handleToggle(id) {
      const wrap   = document.getElementById('form-' + id);
      const toggle = document.getElementById('toggle-' + id);
      const isOpen = wrap.classList.contains('open');

      // Close all open forms first
      document.querySelectorAll('.product-form-wrap.open').forEach(el => el.classList.remove('open'));
      document.querySelectorAll('.product-toggle.open').forEach(el => {
        el.classList.remove('open');
        el.setAttribute('aria-expanded', 'false');
        el.querySelector('span').textContent = 'Get Free Access';
      });

      if (!isOpen) {
        wrap.classList.add('open');
        toggle.classList.add('open');
        toggle.setAttribute('aria-expanded', 'true');
        toggle.querySelector('span').textContent = 'Close';
        setTimeout(() => {
          wrap.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }, 60);
      }
    }
  </script>
</body>
</html>
