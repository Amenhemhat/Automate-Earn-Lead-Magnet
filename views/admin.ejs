<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin — Automate&Earn</title>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800;900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root { --dark:#0a0a0f; --card:#13131f; --gold:#d4af37; --gold-light:#f0d060; --teal:#4db6ac; --text:#e8e8f0; --dim:#9090a8; --faint:#5a5a72; --border:rgba(212,175,55,0.15); --border2:rgba(255,255,255,0.07); --green:#22c55e; --red:#ef4444; }
    body { font-family: 'Inter', sans-serif; background: var(--dark); color: var(--text); min-height: 100vh; }
    a { color: var(--gold); text-decoration: none; }

    /* Header */
    header { background: var(--card); border-bottom: 1px solid var(--border); padding: 0 24px; }
    .h-inner { max-width: 1200px; margin: 0 auto; height: 60px; display: flex; align-items: center; justify-content: space-between; }
    .logo { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: 16px; color: var(--gold); }
    .h-actions { display: flex; gap: 12px; align-items: center; }
    .btn { display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; border-radius: 8px; font-size: 12px; font-weight: 700; font-family: 'Montserrat', sans-serif; letter-spacing: 0.05em; cursor: pointer; border: none; transition: opacity 0.2s; text-transform: uppercase; }
    .btn-gold { background: linear-gradient(135deg, var(--gold), var(--gold-light)); color: #000; }
    .btn-outline { background: transparent; border: 1px solid var(--border2); color: var(--dim); }
    .btn-green { background: rgba(34,197,94,0.15); border: 1px solid rgba(34,197,94,0.3); color: var(--green); }
    .btn-red { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.25); color: #fca5a5; }
    .btn:hover { opacity: 0.85; }
    a.btn { text-decoration: none; }

    /* Layout */
    .container { max-width: 1200px; margin: 0 auto; padding: 32px 24px; }

    /* Stats row */
    .stats-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 12px; margin-bottom: 32px; }
    .stat-card { background: var(--card); border: 1px solid var(--border2); border-radius: 12px; padding: 20px; text-align: center; }
    .stat-num { font-family: 'Montserrat', sans-serif; font-size: 32px; font-weight: 900; color: var(--gold); }
    .stat-label { font-size: 11px; color: var(--dim); text-transform: uppercase; letter-spacing: 0.08em; margin-top: 4px; }

    /* Message */
    .message { padding: 12px 16px; background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.25); border-radius: 8px; font-size: 13px; color: var(--green); margin-bottom: 24px; }

    /* Section */
    .section { background: var(--card); border: 1px solid var(--border2); border-radius: 16px; margin-bottom: 24px; overflow: hidden; }
    .section-head { padding: 20px 24px; border-bottom: 1px solid var(--border2); display: flex; align-items: center; justify-content: space-between; }
    .section-title { font-family: 'Montserrat', sans-serif; font-size: 14px; font-weight: 800; color: var(--text); }
    .section-body { padding: 24px; }

    /* Table */
    table { width: 100%; border-collapse: collapse; font-size: 13px; }
    th { text-align: left; padding: 10px 14px; font-size: 10px; font-weight: 800; font-family: 'Montserrat', sans-serif; letter-spacing: 0.08em; text-transform: uppercase; color: var(--dim); border-bottom: 1px solid var(--border2); }
    td { padding: 12px 14px; border-bottom: 1px solid rgba(255,255,255,0.03); color: var(--text); vertical-align: middle; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: rgba(255,255,255,0.02); }
    .email-cell { color: var(--teal); font-size: 12px; }
    .date-cell { color: var(--faint); font-size: 11px; }

    /* Product list */
    .product-row { display: flex; align-items: center; gap: 14px; padding: 12px 0; border-bottom: 1px solid var(--border2); }
    .product-row:last-child { border-bottom: none; }
    .product-thumb { width: 40px; height: 56px; background: var(--dark); border-radius: 6px; overflow: hidden; flex-shrink: 0; }
    .product-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .product-info { flex: 1; }
    .product-name { font-weight: 600; font-size: 13px; margin-bottom: 2px; }
    .product-file { font-size: 11px; color: var(--faint); }
    .product-actions { display: flex; gap: 8px; }

    /* Add product form */
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .form-full { grid-column: 1 / -1; }
    .form-group { display: flex; flex-direction: column; gap: 6px; }
    .form-label { font-size: 11px; font-weight: 700; font-family: 'Montserrat', sans-serif; letter-spacing: 0.08em; text-transform: uppercase; color: var(--dim); }
    .form-input, .form-textarea { padding: 11px 14px; background: rgba(255,255,255,0.04); border: 1px solid var(--border2); border-radius: 8px; color: var(--text); font-size: 13px; font-family: 'Inter', sans-serif; outline: none; transition: border-color 0.2s; }
    .form-input:focus, .form-textarea:focus { border-color: rgba(212,175,55,0.35); }
    .form-textarea { resize: vertical; min-height: 80px; }
    .form-input[type=file] { padding: 8px 14px; color: var(--dim); cursor: pointer; }
    .empty-table { text-align: center; padding: 40px; color: var(--faint); font-size: 13px; }

    @media(max-width:768px) { .form-grid { grid-template-columns: 1fr; } .h-actions { gap: 6px; } }
  </style>
</head>
<body>

<header>
  <div class="h-inner">
    <span class="logo">AE — Admin</span>
    <div class="h-actions">
      <a href="/" target="_blank" class="btn btn-outline">↗ View Store</a>
      <a href="/admin/export" class="btn btn-green">⬇ Export CSV</a>
      <a href="/admin/logout" class="btn btn-outline">Logout</a>
    </div>
  </div>
</header>

<div class="container">

  <!-- Stats -->
  <div class="stats-row">
    <div class="stat-card">
      <div class="stat-num"><%= stats.total_leads || 0 %></div>
      <div class="stat-label">Total Downloads</div>
    </div>
    <div class="stat-card">
      <div class="stat-num" style="color:var(--teal)"><%= stats.unique_emails || 0 %></div>
      <div class="stat-label">Unique Emails</div>
    </div>
    <div class="stat-card">
      <div class="stat-num" style="color:var(--green)"><%= products.filter(p=>p.active).length %></div>
      <div class="stat-label">Active Products</div>
    </div>
    <div class="stat-card">
      <div class="stat-num" style="color:var(--dim)"><%= products.length %></div>
      <div class="stat-label">Total Products</div>
    </div>
  </div>

  <% if (message) { %><div class="message">✅ <%= message.replace(/\+/g, ' ') %></div><% } %>

  <!-- Add Product -->
  <div class="section">
    <div class="section-head">
      <div class="section-title">➕ Add New Product</div>
    </div>
    <div class="section-body">
      <form method="POST" action="/admin/products/add" enctype="multipart/form-data">
        <div class="form-grid">
          <div class="form-group form-full">
            <label class="form-label">Product Title *</label>
            <input class="form-input" type="text" name="title" placeholder="e.g. The 8 Levels of Claude Mastery" required>
          </div>
          <div class="form-group form-full">
            <label class="form-label">Description (shown on store card)</label>
            <textarea class="form-textarea" name="description" placeholder="Short description of what this guide covers and who it's for..."></textarea>
          </div>
          <div class="form-group">
            <label class="form-label">PDF File * (.pdf)</label>
            <input class="form-input" type="file" name="pdf" accept=".pdf" required>
          </div>
          <div class="form-group">
            <label class="form-label">Cover Image (portrait recommended)</label>
            <input class="form-input" type="file" name="cover" accept="image/*">
          </div>
          <div class="form-group">
            <label class="form-label">Display Order (0 = first)</label>
            <input class="form-input" type="number" name="order_index" value="0" min="0">
          </div>
          <div class="form-group" style="justify-content:flex-end">
            <button type="submit" class="btn btn-gold" style="padding:12px 24px;font-size:13px">Upload Product →</button>
          </div>
        </div>
      </form>
    </div>
  </div>

  <!-- Products -->
  <div class="section">
    <div class="section-head">
      <div class="section-title">📦 Products (<%= products.length %>)</div>
    </div>
    <div class="section-body">
      <% if (products.length === 0) { %>
        <div class="empty-table">No products yet. Add one above.</div>
      <% } else { %>
        <% products.forEach(p => { %>
          <div class="product-row">
            <div class="product-thumb">
              <% if (p.cover_image) { %>
                <img src="/uploads/images/<%= p.cover_image %>" alt="">
              <% } %>
            </div>
            <div class="product-info">
              <div class="product-name"><%= p.title %> <% if (!p.active) { %><span style="font-size:10px;color:var(--faint)">(hidden)</span><% } %></div>
              <div class="product-file">📄 <%= p.filename %></div>
            </div>
            <div class="product-actions">
              <form method="POST" action="/admin/products/<%= p.id %>/toggle" style="display:inline">
                <button type="submit" class="btn btn-outline" style="font-size:11px"><%= p.active ? 'Hide' : 'Show' %></button>
              </form>
              <form method="POST" action="/admin/products/<%= p.id %>/delete" style="display:inline" onsubmit="return confirm('Delete this product and all its leads?')">
                <button type="submit" class="btn btn-red" style="font-size:11px">Delete</button>
              </form>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>

  <!-- Leads -->
  <div class="section">
    <div class="section-head">
      <div class="section-title">📧 Leads (<%= leads.length %>)</div>
      <a href="/admin/export" class="btn btn-green" style="font-size:11px">⬇ Export CSV</a>
    </div>
    <div class="section-body" style="padding:0;overflow-x:auto">
      <% if (leads.length === 0) { %>
        <div class="empty-table">No leads yet. Share your store link to start collecting.</div>
      <% } else { %>
        <table>
          <thead>
            <tr>
              <th>#</th>
              <th>Name</th>
              <th>Email</th>
              <th>Product</th>
              <th>Downloaded</th>
            </tr>
          </thead>
          <tbody>
            <% leads.forEach((lead, i) => { %>
              <tr>
                <td style="color:var(--faint)"><%= leads.length - i %></td>
                <td><%= lead.name %></td>
                <td class="email-cell"><%= lead.email %></td>
                <td style="color:var(--dim);font-size:12px"><%= lead.product_title || '—' %></td>
                <td class="date-cell"><%= new Date(lead.downloaded_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>

</div>
</body>
</html>
